# Project identity
COMPOSE_PROJECT_NAME=whatsaapia-platform
DOCKER_NETWORK_NAME=whatsapp-platform

# Public host ports
CONNECTOR_HOST_PORT=3000
BACKEND_HOST_PORT=8000
DASHBOARD_HOST_PORT=3001
RABBITMQ_MANAGEMENT_PORT=15672

# Public browser-facing URLs baked into whatsapp-dashboard at build time
PUBLIC_CONNECTOR_API_URL=http://localhost:3000
PUBLIC_CONNECTOR_WS_URL=http://localhost:3000
PUBLIC_RULES_API_URL=/rules-api

# Shared tenant/API credentials
TENANT_ID=local-admin
API_KEY_SECRET=19384b690e211d150d43d354fec98a48d1138166d1dd3091
AUTH_ENABLED=true

# Shared webhook secret used by whatsapp-connector and whatsaap-backend
WEBHOOK_SECRET=3838c3b79077c3c0203869207d84556a83ad2fed045ec524e84019cf16717468
WEBHOOK_ENABLED=true
WEBHOOK_PROCESSING_MODE=direct

# WhatsApp session encryption key: base64 of exactly 32 bytes
AUTH_STATE_ENCRYPTION_KEY=w/Qrr8ysLLkzAlZd2MTo2W67w2A71iA0BfkC8Fg1qME=

# Runtime modes
NODE_ENV=production
APP_ENV=development
CONNECTOR_LOG_LEVEL=info
BACKEND_LOG_LEVEL=INFO

# PostgreSQL shared by backend migrations and optional connector persistence
POSTGRES_DB=whatsapp_connector
POSTGRES_USER=wac
POSTGRES_PASSWORD=f9a02c24135db3236dd8abbec70f8e33b2d9
DATABASE_SCHEMA=automation_schema
DB_POOL_SIZE=10

# RabbitMQ shared event bus
RABBITMQ_DEFAULT_USER=automation
RABBITMQ_DEFAULT_PASS=WNlLokc70GGVv0pVjPrShbhYAbwV3zC0
RABBITMQ_DEFAULT_VHOST=whatsapp
RABBITMQ_PREFETCH=10
RABBITMQ_TOPOLOGY_ENABLED=true

# Connector runtime
SESSION_PROVIDER=valkey
ENABLE_VALKEY=true
CONNECTOR_ENABLE_POSTGRES=false
MAX_SESSIONS=10
RECONNECT_INTERVAL_MS=5000
MAX_RECONNECT_ATTEMPTS=5
HEARTBEAT_INTERVAL_MS=30000
ENABLE_WEBSOCKET=true
ENABLE_EVENTS=true
CORS_ENABLED=true
CONNECTOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
MAX_MEDIA_SIZE_MB=16
RATE_LIMIT_MAX_PER_MINUTE=20
RATE_LIMIT_MIN_DELAY_MS=500
HTTP_RATE_LIMIT_TTL_MS=60000
HTTP_RATE_LIMIT_MAX=120
METRICS_ENABLED=true
HEALTH_MAX_HEAP_MB=1024
SWAGGER_ENABLED=false
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# Backend runtime
BACKEND_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
CONNECTOR_TIMEOUT_SECONDS=10
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_STALE_LOCK_SECONDS=300
