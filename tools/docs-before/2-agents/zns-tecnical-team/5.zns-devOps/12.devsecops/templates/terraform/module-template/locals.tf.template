# ============================================================================
# [MODULE_NAME] MODULE - LOCAL VALUES
# ============================================================================

locals {
  # ----------------------------------------------------------------------------
  # NAMING
  # ----------------------------------------------------------------------------
  # Patrón: {project}-{environment}-{service}-{resource}
  module_name = "[module-name]"

  # ----------------------------------------------------------------------------
  # COMMON TAGS
  # ----------------------------------------------------------------------------
  common_tags = merge(var.tags, {
    Environment = var.environment
    Module      = local.module_name
    ManagedBy   = "terraform"
  })

  # ----------------------------------------------------------------------------
  # ENVIRONMENT-SPECIFIC CONFIGURATION
  # ----------------------------------------------------------------------------
  environment_config = {
    dev = {
      instance_size = "small"
      enable_ha     = false
      backup_days   = 1
    }
    staging = {
      instance_size = "medium"
      enable_ha     = false
      backup_days   = 7
    }
    prod = {
      instance_size = "large"
      enable_ha     = true
      backup_days   = 30
    }
  }

  # Configuración actual basada en ambiente
  current_config = local.environment_config[var.environment]

  # ----------------------------------------------------------------------------
  # COMPUTED VALUES
  # ----------------------------------------------------------------------------
  # Ejemplo: Calcular valores derivados
  # full_name = "${var.name_prefix}-${local.module_name}"
  # is_production = var.environment == "prod"
}
