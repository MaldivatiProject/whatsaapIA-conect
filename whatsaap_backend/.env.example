APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Orígenes permitidos para llamar la API de reglas (el dashboard). Incluir
# tanto localhost como 127.0.0.1 evita bloqueos CORS silenciosos ("Network
# Error" en el navegador) según cómo el usuario acceda al dashboard.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Reutiliza PostgreSQL del deployment whatsapp-connector; schema aislado.
DATABASE_URL=postgresql+asyncpg://wac:change-me@postgres:5432/whatsapp_connector
DATABASE_SCHEMA=automation_schema
DB_POOL_SIZE=10

# Flyway usa JDBC sobre la misma instancia/database.
FLYWAY_URL=jdbc:postgresql://postgres:5432/whatsapp_connector
FLYWAY_USER=wac
FLYWAY_PASSWORD=change-me

# Reutiliza Valkey del deployment whatsapp-connector.
VALKEY_URL=redis://valkey:6379/1

# RabbitMQ compartido por connector/backend.
RABBITMQ_URL=amqp://automation:change-me-rabbitmq@rabbitmq:5672/whatsapp
RABBITMQ_PREFETCH=10
RABBITMQ_TOPOLOGY_ENABLED=true

# Connector existente.
CONNECTOR_BASE_URL=http://whatsapp-connector:3000
CONNECTOR_API_KEY=change-me
CONNECTOR_TIMEOUT_SECONDS=10

# API tenant keys: ownerId:secret (secret >= 16 caracteres).
API_KEYS=acme:change-me-to-a-long-random-secret
AUTH_ENABLED=true

# Debe coincidir con WEBHOOK_SECRET en whatsapp-connector.
WEBHOOK_SECRET=change-me-to-at-least-32-characters
WEBHOOK_DEFAULT_TENANT_ID=acme
WEBHOOK_PROCESSING_MODE=outbox

OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_STALE_LOCK_SECONDS=300
