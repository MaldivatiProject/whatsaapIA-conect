# Project identity
COMPOSE_PROJECT_NAME=whatsaapia-platform
DOCKER_NETWORK_NAME=whatsapp-platform

# Public host ports
CONNECTOR_HOST_PORT=3000
BACKEND_HOST_PORT=8000
DASHBOARD_HOST_PORT=3001
RABBITMQ_MANAGEMENT_PORT=15672

# Public browser-facing URLs baked into whatsapp-dashboard at build time.
# Leave the two below EMPTY (default): the dashboard auto-detects the
# connector's origin from whatever host/IP the browser used to load it, so
# it keeps working over localhost, a LAN IP, or a laptop's IP changing on
# DHCP without a rebuild. Only set them if whatsapp-connector is NOT reachable
# on the same host as this dashboard (e.g. split across two machines/domains).
PUBLIC_CONNECTOR_API_URL=
PUBLIC_CONNECTOR_WS_URL=
PUBLIC_RULES_API_URL=/rules-api
# Set to true only if a TLS-terminating reverse proxy sits in front of this
# deployment. Leaving it false on a plain-HTTP deployment is required —
# otherwise the dashboard's CSP tells browsers to upgrade every asset
# request to HTTPS, which fails and leaves the page blank/unstyled.
PUBLIC_HTTPS_ENABLED=false

# Shared tenant/API credentials
TENANT_ID=acme
API_KEY_SECRET=change-me-to-a-long-random-secret
AUTH_ENABLED=true

# Shared webhook secret used by whatsapp-connector and whatsaap-backend
WEBHOOK_SECRET=change-me-to-at-least-32-characters
WEBHOOK_ENABLED=true
WEBHOOK_PROCESSING_MODE=outbox

# WhatsApp session encryption key: base64 of exactly 32 bytes
AUTH_STATE_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=

# pgcrypto passphrase for automation_schema.secrets (RUN_SCRIPT credentials).
# Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=change-me-to-a-long-random-secret-at-least-32-chars

# Runtime modes
NODE_ENV=development
APP_ENV=development
CONNECTOR_LOG_LEVEL=info
BACKEND_LOG_LEVEL=INFO

# PostgreSQL shared by backend migrations and optional connector persistence
POSTGRES_DB=whatsapp_connector
POSTGRES_USER=wac
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432
DATABASE_SCHEMA=automation_schema
DB_POOL_SIZE=10

# RabbitMQ shared event bus
RABBITMQ_DEFAULT_USER=automation
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq
RABBITMQ_DEFAULT_VHOST=whatsapp
RABBITMQ_PREFETCH=10
RABBITMQ_TOPOLOGY_ENABLED=true

# Connector runtime
SESSION_PROVIDER=valkey
ENABLE_VALKEY=true
CONNECTOR_ENABLE_POSTGRES=false
MAX_SESSIONS=10
RECONNECT_INTERVAL_MS=5000
MAX_RECONNECT_ATTEMPTS=5
HEARTBEAT_INTERVAL_MS=30000
ENABLE_WEBSOCKET=true
ENABLE_EVENTS=true
CORS_ENABLED=true
CONNECTOR_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
MAX_MEDIA_SIZE_MB=16
RATE_LIMIT_MAX_PER_MINUTE=20
RATE_LIMIT_MIN_DELAY_MS=500
HTTP_RATE_LIMIT_TTL_MS=60000
HTTP_RATE_LIMIT_MAX=120
METRICS_ENABLED=true
HEALTH_MAX_HEAP_MB=1024
SWAGGER_ENABLED=false
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=

# Backend runtime
BACKEND_CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
CONNECTOR_TIMEOUT_SECONDS=10
OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_STALE_LOCK_SECONDS=300
