# ─────────────────────────────────────────────
# whatsapp-connector — .env.example
# Copia este archivo a .env y ajusta los valores
# ─────────────────────────────────────────────

# ── Servidor ──────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ── Sesiones ──────────────────────────────────
SESSION_PATH=./sessions
MAX_SESSIONS=10

# ── Reconexión ────────────────────────────────
RECONNECT_INTERVAL_MS=5000
MAX_RECONNECT_ATTEMPTS=5
HEARTBEAT_INTERVAL_MS=30000

# ── Medios ────────────────────────────────────
MAX_MEDIA_SIZE_MB=16
# Tipos MIME separados por coma
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,video/mp4,audio/ogg,audio/mpeg,application/pdf

# ── CORS ──────────────────────────────────────
CORS_ENABLED=true
# Orígenes separados por coma. Usar * solo en desarrollo.
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ── Features ──────────────────────────────────
ENABLE_WEBSOCKET=true
ENABLE_EVENTS=true

# ── Persistencia ──────────────────────────────
# Proveedor de sesiones: filesystem | valkey | postgres
SESSION_PROVIDER=filesystem

ENABLE_VALKEY=false
# Valkey utiliza el esquema URI redis:// por compatibilidad con RESP.
VALKEY_URL=redis://localhost:6379
# Base64 de 32 bytes; obligatorio en producción para cifrar credenciales WhatsApp.
AUTH_STATE_ENCRYPTION_KEY=

ENABLE_POSTGRES=false
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_connector

# ── RabbitMQ compartido para backend event-driven ───────────────
# Se levanta con: docker compose --profile rabbitmq up -d rabbitmq
RABBITMQ_DEFAULT_USER=automation
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq
RABBITMQ_DEFAULT_VHOST=whatsapp
RABBITMQ_MANAGEMENT_PORT=15672

# ── Eventos Webhook ───────────────────────────
# Si se habilita, los eventos se envían a esta URL via POST
WEBHOOK_ENABLED=false
WEBHOOK_URL=http://localhost:4000/webhook
WEBHOOK_SECRET=your-webhook-secret-here

# ── Rate Limiting Baileys ─────────────────────
RATE_LIMIT_MAX_PER_MINUTE=20
RATE_LIMIT_MIN_DELAY_MS=500

# ── Autenticación API ─────────────────────────
# Si AUTH_ENABLED=true, todas las rutas (excepto /health) requieren x-api-key.
# Cada clave mapea a un ownerId (tenant): las sesiones quedan aisladas por owner.
# Formato: "ownerId:secret,ownerId2:secret2"  (secret >= 16 caracteres)
AUTH_ENABLED=true
API_KEYS=acme:change-me-to-a-long-random-secret

# ── Rate Limiting HTTP ────────────────────────
HTTP_RATE_LIMIT_TTL_MS=60000
HTTP_RATE_LIMIT_MAX=120

# ── Observabilidad ────────────────────────────
METRICS_ENABLED=true
HEALTH_MAX_HEAP_MB=1024
# Swagger UI en /docs. Por defecto: activado fuera de producción.
# SWAGGER_ENABLED=true

# ── TLS / SSL ─────────────────────────────────
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=
