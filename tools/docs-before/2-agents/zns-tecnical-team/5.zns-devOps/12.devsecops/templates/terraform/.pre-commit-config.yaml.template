# ============================================================================
# PRE-COMMIT CONFIGURATION FOR TERRAFORM
# ============================================================================
# Instalación:
#   pip install pre-commit
#   pre-commit install
#
# Ejecución manual:
#   pre-commit run --all-files
# ============================================================================

repos:
  # ============================================================================
  # TERRAFORM HOOKS
  # ============================================================================
  - repo: https://github.com/antonbabenko/pre-commit-terraform
    rev: v1.86.0
    hooks:
      # Formateo de código
      - id: terraform_fmt

      # Validación de sintaxis
      - id: terraform_validate
        args:
          - --hook-config=--retry-once-with-cleanup=true

      # Generación de documentación
      - id: terraform_docs
        args:
          - --hook-config=--path-to-file=README.md
          - --hook-config=--add-to-existing-file=true
          - --hook-config=--create-file-if-not-exist=true

      # Linting con TFLint
      - id: terraform_tflint
        args:
          - --args=--config=__GIT_WORKING_DIR__/.tflint.hcl

      # Escaneo de seguridad con tfsec
      - id: terraform_tfsec
        args:
          - --args=--minimum-severity=MEDIUM
          - --args=--exclude-downloaded-modules

      # Escaneo con Checkov
      - id: terraform_checkov
        args:
          - --args=--quiet
          - --args=--compact
          - --args=--skip-check=CKV_AWS_18,CKV_AWS_21  # Ajustar según necesidad

      # Limpieza de providers no usados
      - id: terraform_providers_lock
        args:
          - --args=-platform=linux_amd64
          - --args=-platform=darwin_amd64
          - --args=-platform=darwin_arm64

  # ============================================================================
  # GENERAL HOOKS
  # ============================================================================
  - repo: https://github.com/pre-commit/pre-commit-hooks
    rev: v4.5.0
    hooks:
      # Eliminar espacios en blanco al final
      - id: trailing-whitespace
        args: [--markdown-linebreak-ext=md]

      # Asegurar nueva línea al final del archivo
      - id: end-of-file-fixer

      # Validar YAML
      - id: check-yaml
        args: [--allow-multiple-documents]

      # Validar JSON
      - id: check-json

      # Validar archivos grandes
      - id: check-added-large-files
        args: ['--maxkb=1024']

      # Detectar credenciales AWS
      - id: detect-aws-credentials
        args: [--allow-missing-credentials]

      # Detectar claves privadas
      - id: detect-private-key

      # Verificar merge conflicts
      - id: check-merge-conflict

      # Verificar archivos ejecutables tienen shebang
      - id: check-executables-have-shebangs

      # Verificar case sensitivity en nombres de archivo
      - id: check-case-conflict

  # ============================================================================
  # SECRETS DETECTION
  # ============================================================================
  - repo: https://github.com/Yelp/detect-secrets
    rev: v1.4.0
    hooks:
      - id: detect-secrets
        args: ['--baseline', '.secrets.baseline']
        exclude: package.lock.json

  # ============================================================================
  # MARKDOWN LINTING
  # ============================================================================
  - repo: https://github.com/igorshubovych/markdownlint-cli
    rev: v0.38.0
    hooks:
      - id: markdownlint
        args: ['--fix']

  # ============================================================================
  # SHELL SCRIPT LINTING
  # ============================================================================
  - repo: https://github.com/shellcheck-py/shellcheck-py
    rev: v0.9.0.6
    hooks:
      - id: shellcheck
        args: ['--severity=warning']

  # ============================================================================
  # GIT COMMIT MESSAGE
  # ============================================================================
  - repo: https://github.com/commitizen-tools/commitizen
    rev: v3.13.0
    hooks:
      - id: commitizen
        stages: [commit-msg]

# ============================================================================
# CONFIGURACIÓN GLOBAL
# ============================================================================
default_language_version:
  python: python3

# Excluir directorios
exclude: |
  (?x)^(
    \.terraform/|
    \.terragrunt-cache/|
    vendor/|
    node_modules/|
    \.git/
  )
