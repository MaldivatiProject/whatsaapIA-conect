{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whatsaap-backend.local/contracts/amqp/message-envelope.v1.schema.json",
  "title": "WhatsApp Automation Message Envelope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "message_id",
    "message_type",
    "schema_version",
    "occurred_at",
    "producer",
    "correlation_id",
    "tenant_id",
    "content_type",
    "payload"
  ],
  "properties": {
    "message_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "message_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "producer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "causation_id": {
      "type": ["string", "null"],
      "maxLength": 128
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "content_type": {
      "type": "string",
      "const": "application/json"
    },
    "payload": {
      "type": "object"
    }
  }
}
