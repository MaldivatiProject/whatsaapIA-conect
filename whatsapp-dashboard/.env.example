# URL pública de whatsapp-connector (REST). Se ingresa en build-time (NEXT_PUBLIC_*).
NEXT_PUBLIC_CONNECTOR_API_URL=http://localhost:3000

# URL del servidor WebSocket (socket.io) de whatsapp-connector. Normalmente igual a la de arriba.
NEXT_PUBLIC_CONNECTOR_WS_URL=http://localhost:3000

# URL pública para el navegador. En Docker usa el proxy same-origin de Next.js.
NEXT_PUBLIC_RULES_API_URL=/rules-api

# URL interna Docker usada por el proxy de Next.js /rules-api/*.
RULES_INTERNAL_API_URL=http://whatsaap-backend-api:8000
