# ============================================================================
# TFLINT CONFIGURATION
# ============================================================================
# Documentación: https://github.com/terraform-linters/tflint
# ============================================================================

config {
  # Habilitar verificación de módulos
  module = true
  
  # Forzar errores en lugar de warnings para reglas importantes
  force = false
}

# ============================================================================
# AWS PLUGIN
# ============================================================================
plugin "aws" {
  enabled = true
  version = "0.28.0"
  source  = "github.com/terraform-linters/tflint-ruleset-aws"
}

# ============================================================================
# TERRAFORM RULES
# ============================================================================

# Naming convention para recursos
rule "terraform_naming_convention" {
  enabled = true
  format  = "snake_case"
  
  custom_formats = {
    # Permitir kebab-case para ciertos recursos si es necesario
    # aws_s3_bucket = {
    #   format = "^[a-z0-9-]+$"
    # }
  }
}

# Variables deben tener descripción
rule "terraform_documented_variables" {
  enabled = true
}

# Outputs deben tener descripción
rule "terraform_documented_outputs" {
  enabled = true
}

# Variables deben tener tipo
rule "terraform_typed_variables" {
  enabled = true
}

# Deprecación de sintaxis
rule "terraform_deprecated_interpolation" {
  enabled = true
}

# Detectar variables no utilizadas
rule "terraform_unused_declarations" {
  enabled = true
}

# Detectar required_providers faltantes
rule "terraform_required_providers" {
  enabled = true
}

# Detectar required_version faltante
rule "terraform_required_version" {
  enabled = true
}

# Standard module structure
rule "terraform_standard_module_structure" {
  enabled = true
}

# Comentarios en línea
rule "terraform_comment_syntax" {
  enabled = true
}

# Espaciado consistente
rule "terraform_empty_list_equality" {
  enabled = true
}

# ============================================================================
# AWS SPECIFIC RULES
# ============================================================================

# Validar tipos de instancia
rule "aws_instance_invalid_type" {
  enabled = true
}

# Validar AMIs
rule "aws_instance_invalid_ami" {
  enabled = true
}

# Detectar tipos de instancia anteriores
rule "aws_instance_previous_type" {
  enabled = true
}

# Validar tipos de RDS
rule "aws_db_instance_invalid_type" {
  enabled = true
}

# Validar engine versions de RDS
rule "aws_db_instance_invalid_engine" {
  enabled = true
}

# Validar tipos de ElastiCache
rule "aws_elasticache_cluster_invalid_type" {
  enabled = true
}

# Validar regiones
rule "aws_route_invalid_route_table_id" {
  enabled = true
}

# Recursos deben tener tags
rule "aws_resource_missing_tags" {
  enabled = true
  tags = [
    "Environment",
    "Project",
    "ManagedBy"
  ]
  
  # Excluir recursos que no soportan tags
  exclude = [
    "aws_iam_policy",
    "aws_iam_role_policy",
    "aws_iam_group_policy",
    "aws_iam_user_policy"
  ]
}

# ============================================================================
# REGLAS PERSONALIZADAS
# ============================================================================

# Asegurar que S3 buckets tienen encryption
rule "aws_s3_bucket_invalid_acl" {
  enabled = true
}

# Verificar security groups no tienen reglas demasiado permisivas
rule "aws_security_group_invalid_rule" {
  enabled = false  # Usar tfsec para esto
}

# ============================================================================
# REGLAS DESHABILITADAS
# ============================================================================
# Deshabilitar reglas que son manejadas por otras herramientas

# Manejado por tfsec
rule "aws_db_instance_readable_password" {
  enabled = false
}
