APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Reutiliza el Postgres del deployment whatsapp-connector; schema aislado.
DATABASE_URL=postgresql+asyncpg://wac:f9a02c24135db3236dd8abbec70f8e33b2d9@postgres:5432/whatsapp_connector
DATABASE_SCHEMA=automation_schema
DB_POOL_SIZE=10

FLYWAY_URL=jdbc:postgresql://postgres:5432/whatsapp_connector
FLYWAY_USER=wac
FLYWAY_PASSWORD=f9a02c24135db3236dd8abbec70f8e33b2d9

VALKEY_URL=redis://valkey:6379/1

RABBITMQ_URL=amqp://automation:change-me-rabbitmq@rabbitmq:5672/whatsapp
RABBITMQ_PREFETCH=10
RABBITMQ_TOPOLOGY_ENABLED=true

# Llama de vuelta a whatsapp-connector para enviar la respuesta (fase 1: directo, sin RabbitMQ).
CONNECTOR_BASE_URL=http://whatsapp-connector:3000
CONNECTOR_API_KEY=19384b690e211d150d43d354fec98a48d1138166d1dd3091
CONNECTOR_TIMEOUT_SECONDS=10

# Mismo secret que API_KEYS de whatsapp-connector para el owner local-admin,
# asi la misma api key del dashboard funciona contra ambos servicios.
API_KEYS=local-admin:19384b690e211d150d43d354fec98a48d1138166d1dd3091
AUTH_ENABLED=true

# Debe coincidir con WEBHOOK_SECRET en whatsapp-connector/.env
WEBHOOK_SECRET=3838c3b79077c3c0203869207d84556a83ad2fed045ec524e84019cf16717468
WEBHOOK_DEFAULT_TENANT_ID=local-admin
WEBHOOK_PROCESSING_MODE=outbox

OUTBOX_BATCH_SIZE=50
OUTBOX_POLL_INTERVAL_SECONDS=1
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_STALE_LOCK_SECONDS=300

# El panel back.alocredit.co es lento cargando el menú tras el login;
# se subió de 90s (default) para dar margen a los waits de Selenium.
SCRIPT_SANDBOX_TIMEOUT_SECONDS=120
